{
  "entities": {
    "Agent": {
      "title": "Agent",
      "description": "An autonomous security agent in the ASRO system.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "status": { "type": "string", "enum": ["idle", "busy", "error"] },
        "purpose": { "type": "string" },
        "trigger": { "type": "string" },
        "icon": { "type": "string" },
        "userId": { "type": "string" },
        "lastAction": { "type": "string" },
        "lastActionTime": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "role", "status", "userId"]
    },
    "PipelineStage": {
      "title": "Pipeline Stage",
      "description": "A stage in the security pipeline.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["success", "failed", "running", "pending"] },
        "score": { "type": "integer" },
        "duration": { "type": "string" },
        "blocking": { "type": "boolean" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["id", "name", "status", "userId"]
    },
    "SustainabilityMetric": {
      "title": "Sustainability Metric",
      "description": "Environmental impact metrics for the pipeline.",
      "type": "object",
      "properties": {
        "carbonFootprint": { "type": "number" },
        "energyUsage": { "type": "number" },
        "greenScore": { "type": "integer" },
        "optimizationSavings": { "type": "number" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["userId"]
    },
    "UserTask": {
      "title": "User Task",
      "description": "A task assigned to the user for manual review or action.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status": { "type": "string", "enum": ["open", "in-progress", "completed"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["title", "priority", "status", "userId"]
    },
    "UserSession": {
      "title": "User Session",
      "description": "A record of a user's session in the dashboard.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "duration": { "type": "string" },
        "actions": { "type": "integer" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["timestamp", "userId"]
    },
    "Vulnerability": {
      "title": "Vulnerability",
      "description": "A security vulnerability detected in a project.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "status": { "type": "string", "enum": ["detected", "patching", "patched", "ignored"] },
        "description": { "type": "string" },
        "file": { "type": "string" },
        "line": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["title", "severity", "status", "userId"]
    },
    "ActivityLog": {
      "title": "Activity Log",
      "description": "A log of actions performed by agents or users.",
      "type": "object",
      "properties": {
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "agentId": { "type": "string" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["timestamp", "type", "message", "userId"]
    },
    "Pipeline": {
      "title": "Pipeline",
      "description": "A GitLab pipeline execution record.",
      "type": "object",
      "properties": {
        "status": { "type": "string" },
        "ref": { "type": "string" },
        "webUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "projectId": { "type": "string" }
      },
      "required": ["status", "ref", "userId"]
    },
    "Project": {
      "title": "Project",
      "description": "A project monitored by ASRO.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "path_with_namespace": { "type": "string" },
        "avatar_url": { "type": "string", "format": "uri" },
        "web_url": { "type": "string", "format": "uri" },
        "star_count": { "type": "integer" },
        "forks_count": { "type": "integer" },
        "last_activity_at": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["gitlab", "github"] },
        "addedAt": { "type": "string", "format": "date-time" },
        "addedBy": { "type": "string" }
      },
      "required": ["id", "name", "addedBy"]
    }
  },
  "firestore": {
    "agents": { "schema": "Agent", "description": "Collection of autonomous agents." },
    "pipeline_stages": { "schema": "PipelineStage", "description": "Stages of the security pipeline." },
    "sustainability_metrics": { "schema": "SustainabilityMetric", "description": "Environmental impact data." },
    "user_tasks": { "schema": "UserTask", "description": "Tasks for user review." },
    "user_sessions": { "schema": "UserSession", "description": "User activity sessions." },
    "vulnerabilities": { "schema": "Vulnerability", "description": "Detected security issues." },
    "activity_logs": { "schema": "ActivityLog", "description": "System activity logs." },
    "pipelines": { "schema": "Pipeline", "description": "GitLab pipeline records." },
    "projects": { "schema": "Project", "description": "Monitored repositories." }
  }
}
