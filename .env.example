# === Gemini AI Configuration ===
# Get API key from: https://ai.google.dev/
GEMINI_API_KEY=AIzaSyA-swTtbMnUJswL3_w8a_OXoGclB2pdiuM

# === Application URL ===
# The URL where this applet is hosted
