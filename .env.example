# === GitLab Integration ===
# Get token from: GitLab → Settings → Access Tokens
# Scopes required: api, read_repository
VITE_GITLAB_API_URL=https://gitlab.com/api/v4
VITE_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxx
VITE_GITLAB_PROJECT_ID=79598942

# GitLab legacy format (deprecated, use VITE_ prefix)
GITLAB_TOKEN=glpat-gK_WhK24iczt8Q1CsiNtNm86MQp1Omt5bTl2Cw.01.120d2nbdf
GITLAB_PROJECT_ID=79598942
GITLAB_BASE_URL=https://gitlab.com/api/v4

# === Auto-refresh Settings ===
# Enable automatic data refresh from GitLab
VITE_AUTO_REFRESH_ENABLED=true

# Refresh interval in milliseconds (default: 30000 = 30 seconds)
VITE_REFRESH_INTERVAL=30000

# === Firebase Configuration (Optional) ===
