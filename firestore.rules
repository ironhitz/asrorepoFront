rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "jonblakk@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Agent Validation
    function isValidAgent(data) {
      return data.name is string && data.name.size() > 0 &&
             data.role is string && data.role.size() > 0 &&
             data.status in ['idle', 'busy', 'error'] &&
             data.userId == request.auth.uid;
    }

    match /agents/{agentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidAgent(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidAgent(request.resource.data);
      allow delete: if isAdmin();
    }

    // Vulnerability Validation
    function isValidVulnerability(data) {
      return data.title is string && data.title.size() > 0 &&
             data.severity in ['critical', 'high', 'medium', 'low'] &&
             data.status in ['detected', 'patching', 'patched', 'verified', 'ignored'] &&
             data.userId == request.auth.uid;
    }

    match /vulnerabilities/{vulnId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidVulnerability(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidVulnerability(request.resource.data);
      allow delete: if isAdmin();
    }

    // Activity Log Validation
    function isValidActivityLog(data) {
      return data.type is string && data.type.size() > 0 &&
             data.message is string && data.message.size() > 0 &&
             data.userId == request.auth.uid;
    }

    match /activity_logs/{logId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidActivityLog(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Pipeline Validation
    function isValidPipeline(data) {
      return data.status is string && data.status.size() > 0 &&
             data.userId == request.auth.uid;
    }

    match /pipelines/{pipelineId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidPipeline(request.resource.data);
      allow update, delete: if isAdmin();
    }

    // Project Validation
    function isValidProject(data) {
      return data.name is string && data.name.size() > 0 &&
             data.path_with_namespace is string && data.path_with_namespace.size() > 0 &&
             data.web_url is string && data.web_url.size() > 0 &&
             data.addedBy == request.auth.uid;
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated() && (resource.data.addedBy == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.addedBy == request.auth.uid);
    }

    // Plugin Validation
    function isValidUserPlugin(data) {
      return data.name is string && data.name.size() > 0 &&
             data.repoUrl is string && data.repoUrl.size() > 0 &&
             data.version is string && data.version.size() > 0 &&
             data.userId == request.auth.uid;
    }

    match /user_plugins/{pluginId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.teamId == request.auth.token.teamId || isAdmin());
      allow create: if isAuthenticated() && isValidUserPlugin(request.resource.data);
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin()) && isValidUserPlugin(request.resource.data);
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    function isValidTeamPlugin(data) {
      return data.name is string && data.name.size() > 0 &&
             data.version is string && data.version.size() > 0 &&
             data.userId == request.auth.uid;
    }

    match /team_plugins/{pluginId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTeamPlugin(request.resource.data);
      allow update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // User Profile
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
